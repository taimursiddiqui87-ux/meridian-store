# ─────────────────────────────────────────────────────────────
# MERIDIAN — environment template
# Copy to `.env`, fill in the values, and add the same values to
# Vercel → Project → Settings → Environment Variables.
# Full walkthrough: SETUP.md
# ─────────────────────────────────────────────────────────────

# 1) DATABASE — Neon Postgres (https://neon.tech → create project → copy connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# 2) AUTH — session signing secret. Generate one:  openssl rand -base64 32
AUTH_SECRET=""

# 3) PAYMENTS — Cash on Delivery works with no setup.
# Card / JazzCash / Easypaisa run in demo mode until you add merchant
# gateway credentials (e.g. JAZZCASH_MERCHANT_ID / _PASSWORD / _SALT,
# EASYPAISA_STORE_ID / _HASH_KEY) once your merchant accounts are approved.

# 4) RESEND — https://resend.com/api-keys
RESEND_API_KEY="re_xxx"
# Use onboarding@resend.dev for testing, or a verified domain for production
EMAIL_FROM="MERIDIAN <onboarding@resend.dev>"

# 5) APP URL — used for Stripe redirect URLs
# Local: http://localhost:3000   ·   Vercel: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 6) ADMIN LOGIN — dedicated backend login at /admin/login (separate from customers).
# Defaults to admin / 1234@ if unset. CHANGE THESE before real production use.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="1234@"
# Email that receives the "new order" admin notification (customers are emailed too)
ADMIN_EMAIL="you@email.com"
