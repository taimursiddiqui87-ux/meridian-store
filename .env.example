# ─────────────────────────────────────────────────────────────
# MERIDIAN — environment template
# Copy to `.env`, fill in the values, and add the same values to
# Vercel → Project → Settings → Environment Variables.
# Full walkthrough: SETUP.md
# ─────────────────────────────────────────────────────────────

# 1) DATABASE — Neon Postgres (https://neon.tech → create project → copy connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# 2) AUTH — session signing secret. Generate one:  openssl rand -base64 32
AUTH_SECRET=""

# 3) STRIPE (test mode) — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# Webhook signing secret — from `stripe listen` (local) or the Dashboard webhook (prod)
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# 4) RESEND — https://resend.com/api-keys
RESEND_API_KEY="re_xxx"
# Use onboarding@resend.dev for testing, or a verified domain for production
EMAIL_FROM="MERIDIAN <onboarding@resend.dev>"

# 5) APP URL — used for Stripe redirect URLs
# Local: http://localhost:3000   ·   Vercel: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 6) ADMIN — restrict the /admin backend to a single signed-in email.
# Blank = any signed-in user (fine for local dev). Set to your email in production.
ADMIN_EMAIL=""
