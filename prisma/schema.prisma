// MERIDIAN — data model (Phase 2)
// Uses Postgres. Set DATABASE_URL in .env.local (see .env.example / SETUP.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  email           String
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  status          String      @default("pending") // pending | paid | fulfilled | cancelled
  currency        String      @default("usd")
  subtotal        Int // integer cents
  shipping        Int         @default(0)
  tax             Int         @default(0)
  total           Int
  stripeSessionId String?     @unique
  customerName    String?
  shippingAddress String?
  createdAt       DateTime    @default(now())
  items           OrderItem[]

  @@index([userId])
  @@index([email])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  name      String
  variant   String
  price     Int // integer cents
  quantity  Int
  image     String
}

model Banner {
  id             String   @id @default(cuid())
  kind           String   @default("hero") // hero (carousel) | promo
  eyebrow        String?
  title          String
  subtitle       String?
  image          String
  align          String   @default("left") // left | center
  theme          String   @default("dark") // dark | light
  badge          String? // e.g. "Launch Sale", "-20%" — shown as a pill (sale-ready)
  primaryLabel   String?
  primaryHref    String?
  secondaryLabel String?
  secondaryHref  String?
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([kind, active, sortOrder])
}
